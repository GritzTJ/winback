<Window x:Class="WinBack.App.Views.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:WinBack.App.Controls"
        Title="WinBack — Mot de passe de chiffrement"
        Width="420" SizeToContent="Height"
        MinWidth="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource MainWindowStyle}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Icône + titre -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16"
                    ctrl:StackPanelEx.Spacing="10">
            <TextBlock Text="🔒" FontSize="28" VerticalAlignment="Center"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Style="{StaticResource TextSubtitle}"
                           Text="Sauvegarde chiffrée"/>
                <TextBlock x:Name="ProfileNameBlock"
                           Style="{StaticResource TextCaption}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Message explicatif -->
        <TextBlock Grid.Row="1"
                   Text="Ce profil utilise le chiffrement AES-256. Saisissez le mot de passe pour démarrer la sauvegarde."
                   Style="{StaticResource TextBody}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Champ mot de passe -->
        <StackPanel Grid.Row="2" ctrl:StackPanelEx.Spacing="6" Margin="0,0,0,20">
            <TextBlock Text="Mot de passe" Style="{StaticResource TextCaption}" FontWeight="SemiBold"/>
            <PasswordBox x:Name="PasswordBox"
                         KeyDown="PasswordBox_KeyDown"/>
            <TextBlock x:Name="ErrorBlock"
                       Text="Mot de passe incorrect ou vide."
                       Style="{StaticResource TextCaption}"
                       Foreground="Red"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- Boutons OK / Annuler -->
        <Grid Grid.Row="3">
            <Button Content="Annuler"
                    Style="{StaticResource ButtonSecondary}"
                    HorizontalAlignment="Left"
                    Click="Cancel_Click"/>
            <Button Content="Démarrer la sauvegarde"
                    Style="{StaticResource ButtonPrimary}"
                    HorizontalAlignment="Right"
                    Click="Ok_Click"/>
        </Grid>
    </Grid>
</Window>
