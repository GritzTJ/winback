<Window x:Class="WinBack.App.Views.RestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinBack.App.ViewModels"
        xmlns:conv="clr-namespace:WinBack.App.Converters"
        xmlns:ctrl="clr-namespace:WinBack.App.Controls"
        Title="WinBack — Restaurer une sauvegarde"
        Width="580" SizeToContent="Height"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource MainWindowStyle}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- En-tête -->
            <RowDefinition Height="*"/>    <!-- Contenu -->
        </Grid.RowDefinitions>

        <!-- ── En-tête ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center"
                        ctrl:StackPanelEx.Spacing="10">
                <TextBlock Text="🔄" FontSize="20" VerticalAlignment="Center"/>
                <TextBlock Text="Restaurer une sauvegarde" Style="{StaticResource TextTitle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Contenu ──────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" ctrl:StackPanelEx.Spacing="16">

                <!-- Explication -->
                <TextBlock Style="{StaticResource TextBody}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="Choisissez le dossier de sauvegarde source (tel qu'il apparaît sur le disque externe) et le dossier de destination sur cette machine. La structure des sous-dossiers est préservée."/>

                <!-- Dossier source -->
                <Border Style="{StaticResource Card}">
                    <StackPanel ctrl:StackPanelEx.Spacing="12">
                        <TextBlock Text="Dossiers" Style="{StaticResource TextCaption}" FontWeight="SemiBold"/>

                        <StackPanel ctrl:StackPanelEx.Spacing="6">
                            <TextBlock Text="Dossier source (sur le disque de sauvegarde)"
                                       Style="{StaticResource TextCaption}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding SourceFolder, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource TextBoxStyle}"
                                         IsReadOnly="True"/>
                                <Button Grid.Column="1" Content="Parcourir…"
                                        Style="{StaticResource ButtonSecondary}"
                                        Margin="8,0,0,0"
                                        Click="BrowseSource_Click"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel ctrl:StackPanelEx.Spacing="6">
                            <TextBlock Text="Dossier de destination (sur cette machine)"
                                       Style="{StaticResource TextCaption}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource TextBoxStyle}"
                                         IsReadOnly="True"/>
                                <Button Grid.Column="1" Content="Parcourir…"
                                        Style="{StaticResource ButtonSecondary}"
                                        Margin="8,0,0,0"
                                        Click="BrowseDest_Click"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Options chiffrement + écrasement -->
                <Border Style="{StaticResource Card}">
                    <StackPanel ctrl:StackPanelEx.Spacing="12">
                        <TextBlock Text="Options" Style="{StaticResource TextCaption}" FontWeight="SemiBold"/>

                        <CheckBox Content="Les fichiers sont chiffrés (sauvegarde avec AES-256)"
                                  IsChecked="{Binding IsEncrypted}"
                                  Style="{StaticResource CheckBoxStyle}"/>

                        <!-- Champ mot de passe — visible si chiffrement activé -->
                        <StackPanel Visibility="{Binding ShowPasswordField, Converter={StaticResource BoolVis}}"
                                    ctrl:StackPanelEx.Spacing="6">
                            <TextBlock Text="Mot de passe de déchiffrement"
                                       Style="{StaticResource TextCaption}"/>
                            <PasswordBox x:Name="PasswordBox"
                                         PasswordChanged="PasswordBox_Changed"/>
                            <TextBlock Text="Le même mot de passe que celui utilisé lors de la sauvegarde."
                                       Style="{StaticResource TextCaption}"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <CheckBox Content="Écraser les fichiers existants à la destination"
                                  IsChecked="{Binding Overwrite}"
                                  Style="{StaticResource CheckBoxStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Résultat (visible après restauration) -->
                <Border Style="{StaticResource Card}"
                        Visibility="{Binding ShowResult, Converter={StaticResource BoolVis}}">
                    <StackPanel ctrl:StackPanelEx.Spacing="8">
                        <TextBlock Text="Résultat" Style="{StaticResource TextCaption}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ResultText}"
                                   Style="{StaticResource TextBody}"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Spinner progression -->
                <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
                            ctrl:StackPanelEx.Spacing="6">
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource TextCaption}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <ProgressBar Style="{StaticResource ProgressBarStyle}"
                                 IsIndeterminate="True" Height="4"/>
                </StackPanel>

                <!-- Bouton lancer -->
                <Button Content="🔄 Restaurer"
                        Style="{StaticResource ButtonPrimary}"
                        HorizontalAlignment="Right"
                        IsEnabled="{Binding CanStart}"
                        Command="{Binding StartRestoreCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource InvBoolVis}}"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
